    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: radial-gradient(circle at 10% 20%, #0a0f1e, #030712);
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Poppins', sans-serif;
            padding: 2rem 1.2rem;
            min-height: 100vh;
        }

        .container {
            max-width: 580px;
            margin: 0 auto;
        }

        .card {
            background: rgba(6, 14, 26, 0.88);
            backdrop-filter: blur(12px);
            border-radius: 56px;
            padding: 2rem 1.8rem 2.5rem;
            border: 1px solid rgba(0, 123, 255, 0.25);
            box-shadow: 0 35px 55px -15px rgba(0, 0, 0, 0.6), 0 0 0 1px rgba(0, 100, 255, 0.15);
            transition: all 0.2s;
        }

        .logo-box {
            text-align: center;
            margin-bottom: 1rem;
        }
        .logo-img {
            width: 110px;
            height: 110px;
            object-fit: cover;
            border-radius: 35px;
            box-shadow: 0 20px 30px -10px black, 0 0 0 3px #004e9e;
            transition: transform 0.2s;
        }
        .logo-img:hover {
            transform: scale(1.02);
        }

        .brand-name {
            text-align: center;
            font-size: 2.2rem;
            font-weight: 800;
            background: linear-gradient(135deg, #F5E6B2 0%, #FFD966 30%, #FFB347 70%, #FF8C42 100%);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            letter-spacing: -0.5px;
            margin-top: 0.8rem;
            text-shadow: 0 2px 3px rgba(0,0,0,0.3);
        }
        .tagline {
            text-align: center;
            margin-top: 6px;
        }
        .tagline span {
            background: rgba(255, 180, 40, 0.18);
            padding: 5px 16px;
            border-radius: 50px;
            font-size: 0.7rem;
            font-weight: 600;
            color: #FFD966;
            display: inline-block;
            backdrop-filter: blur(4px);
        }

        .btn-wrap {
            margin: 1.6rem 0 1rem;
        }
        
        .tele-btn {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
            background: linear-gradient(95deg, #0A2F6C 0%, #124E8F 50%, #1A5EA8 100%);
            padding: 1rem 1rem;
            border-radius: 80px;
            font-size: 1.18rem;
            font-weight: 700;
            text-decoration: none;
            color: white;
            transition: all 0.25s ease;
            box-shadow: 0 10px 20px -5px rgba(0, 0, 0, 0.5), 0 0 0 1px #2C74C0;
            text-align: center;
            letter-spacing: 0.3px;
            cursor: pointer;
        }
        .tele-btn:hover {
            transform: translateY(-3px);
            background: linear-gradient(95deg, #12488a, #1f66b5);
            box-shadow: 0 18px 28px -8px black;
        }
        .tele-btn:active {
            transform: translateY(1px);
        }

        .btn-second {
            background: linear-gradient(95deg, #0D3A6E 0%, #1F5DA0 50%, #2B6DB8 100%);
            margin-top: 12px;
        }
        .btn-second:hover {
            background: linear-gradient(95deg, #154a82, #2a6db8);
        }

        .market-panel {
            background: rgba(2, 10, 20, 0.7);
            border-radius: 32px;
            padding: 1.4rem 1.5rem;
            margin: 1.5rem 0;
            border: 1px solid #1C4E80;
            box-shadow: inset 0 1px 2px rgba(255,255,255,0.02), 0 6px 12px -8px black;
        }
        .panel-header {
            font-size: 1.2rem;
            font-weight: 800;
            color: #FFDE9C;
            margin-bottom: 1rem;
            display: flex;
            align-items: center;
            gap: 8px;
            border-left: 3px solid #F5A623;
            padding-left: 10px;
        }
        .feature-list {
            list-style: none;
        }
        .feature-list li {
            margin-bottom: 12px;
            display: flex;
            align-items: center;
            gap: 11px;
            font-weight: 500;
            color: #E9F2FF;
            font-size: 0.95rem;
        }
        .feature-list li::before {
            content: "🔥";
            font-size: 1rem;
        }
        .feature-list li:nth-child(2)::before { content: "📊"; }
        .feature-list li:nth-child(3)::before { content: "⚡"; }
        .feature-list li:nth-child(4)::before { content: "💰"; }
        
        .disclaimer-free {
            background: #05152a;
            border-radius: 30px;
            text-align: center;
            padding: 10px;
            font-size: 0.75rem;
            font-weight: 600;
            color: #F5C542;
            margin-top: 16px;
        }
        .live-latest {
            background: #0A1C32;
            border-radius: 28px;
            text-align: center;
            padding: 8px 12px;
            font-size: 0.7rem;
            color: #80C0FF;
            margin-top: 13px;
        }

        .footer-credit {
            text-align: center;
            font-size: 0.65rem;
            margin-top: 1.8rem;
            color: #5c7d9e;
            border-top: 1px solid #1F3A5F;
            padding-top: 1rem;
        }
        
        .event-badge {
            text-align: center;
            font-size: 0.6rem;
            color: #ffb347;
            margin-top: 6px;
            letter-spacing: 0.3px;
        }
        
        /* Toast message */
        .toast-msg {
            position: fixed;
            bottom: 30px;
            left: 50%;
            transform: translateX(-50%);
            background: #0A2F6C;
            color: white;
            padding: 8px 16px;
            border-radius: 40px;
            font-size: 12px;
            font-weight: 500;
            z-index: 1000;
            box-shadow: 0 5px 15px rgba(0,0,0,0.3);
            opacity: 0;
            transition: opacity 0.3s ease;
            pointer-events: none;
            white-space: nowrap;
        }
        .toast-msg.show {
            opacity: 1;
        }
        
        @media (max-width: 500px) {
            .card {
                padding: 1.4rem 1.2rem;
            }
            .brand-name {
                font-size: 1.7rem;
            }
            .tele-btn {
                font-size: 0.95rem;
                padding: 0.8rem 0.8rem;
            }
            .feature-list li {
                font-size: 0.85rem;
            }
            .toast-msg {
                font-size: 10px;
                white-space: nowrap;
                bottom: 20px;
            }
        }
    </style>
</head>
<body>
<div class="container">
    <div class="card">
        
        <!-- LOGO Section -->
        <div class="logo-box">
            <img class="logo-img" src="https://karanmetalabe.com/wp-content/uploads/2025/11/download-9.jpg" alt="PANKAJ BHARDWAJ Logo" onerror="this.src='https://placehold.co/110x110/0B2B5E/white?text=PB'">
        </div>
        
        <div class="brand-name">PANKAJ BHARDWAJ</div>
        <div class="tagline"><span>🎯 NIFTY • BANKNIFTY • OPTIONS MASTER 🎯</span></div>
        
        <!-- FIRST JOIN BUTTON - directly below name -->
        <div class="btn-wrap">
            <a id="joinBtnTop" href="https://t.me/+lxihBXfwZTM0ODI9" target="_blank" class="tele-btn" data-button-name="Join Button Primary (Below Name)" data-position="first_under_name">
                🚀 JOIN TELEGRAM CHANNEL
            </a>
        </div>
        
        <!-- SECOND JOIN BUTTON - second button below name -->
        <div class="btn-wrap">
            <a id="joinBtnBottom" href="https://t.me/+lxihBXfwZTM0ODI9" target="_blank" class="tele-btn btn-second" data-button-name="Join Button Secondary (Below Name 2)" data-position="second_under_name">
                ⚡ GET FREE CALLS → JOIN NOW
            </a>
        </div>
        
        <div class="event-badge">
            🎯 Pixel Tracked: Lead + Subscribe + CompleteRegistration + Contact | Pixel ID: 4954209871473065
        </div>
        
        <!-- STOCK RELATED LINES -->
        <div class="market-panel">
            <div class="panel-header">
                <span>📈</span> NIFTY/BANKNIFTY & OPTIONS EDGE
            </div>
            <ul class="feature-list">
                <li>✅ Target 100-300 Points Per Trade</li>
                <li>✅ 80-90% Accurate Market Calls</li>
                <li>✅ 3-4 Premium Setups Daily</li>
                <li>✅ 3 Daily Best Trades for All</li>
            </ul>
            <div class="disclaimer-free">
                📢 Disclaimer: DAILY FREE DEMO CALL ✅
            </div>
            <div class="live-latest">
                🔴 LIVE STREAMING ANALYSIS • PANKAJ'S SECRET STRATEGY • REAL TIME ENTRY 🔴
            </div>
        </div>
        
        <div class="footer-credit">
            🔐 Instant Access • 7000+ Active Traders • Daily Free Setups <br>
            © PANKAJ BHARDWAJ — Your Trusted Market Navigator
        </div>
    </div>
</div>

<!-- Toast notification -->
<div id="trackingToast" class="toast-msg">✅ Tracking confirmed! Redirecting to Telegram...</div>

<script>
    // ============================================================
    // NEW PIXEL ID: 4954209871473065
    // EXPERT NAME: PANKAJ BHARDWAJ
    // TELEGRAM LINK: https://t.me/+lxihBXfwZTM0ODI9
    // ONLY 2 BUTTONS - Subscribe Button REMOVED
    // ============================================================
    (function() {
        const CONFIG = {
            TELEGRAM_LINK: 'https://t.me/+lxihBXfwZTM0ODI9',
            TELEGRAM_CODE: 'lxihBXfwZTM0ODI9',
            PIXEL_ID: '4954209871473065',
            CHANNEL_NAME: 'PANKAJ_BHARDWAJ',
            EXPERT_NAME: 'PANKAJ BHARDWAJ'
        };
        
        // Helper: Show toast message
        function showToastMessage(message, duration = 1800) {
            const toast = document.getElementById('trackingToast');
            if (toast) {
                toast.textContent = message || '✅ Tracking confirmed! Redirecting to Telegram...';
                toast.classList.add('show');
                setTimeout(function() {
                    toast.classList.remove('show');
                }, duration);
            }
        }
        
        // Helper: Fire all important pixel events
        function fireAllTrackingEvents(buttonElement, buttonName, position) {
            if (typeof fbq !== 'function') {
                console.warn("Facebook Pixel not loaded yet, but link will still work.");
                return;
            }
            
            const eventTime = new Date().toISOString();
            const deviceType = /Mobi|Android|iPhone|iPad|iPod/i.test(navigator.userAgent) ? 'mobile' : 'desktop';
            
            // 1. LEAD event
            fbq('track', 'Lead', {
                content_name: buttonName,
                content_category: 'Telegram_Channel_Join_PankajBhardwaj',
                button_position: position,
                method: 'Telegram_Redirect',
                currency: 'INR',
                value: 0.01,
                channel: CONFIG.CHANNEL_NAME,
                expert: CONFIG.EXPERT_NAME,
                pixel_id: CONFIG.PIXEL_ID,
                device: deviceType,
                telegram_code: CONFIG.TELEGRAM_CODE
            });
            
            // 2. SUBSCRIBE event
            fbq('track', 'Subscribe', {
                content_name: 'Telegram_Channel_Subscription_Pankaj',
                status: 'subscribed',
                button_name: buttonName,
                location: position,
                channel: 'PANKAJ_BHARDWAJ_TELEGRAM',
                expert: CONFIG.EXPERT_NAME,
                pixel_id: CONFIG.PIXEL_ID,
                telegram_code: CONFIG.TELEGRAM_CODE
            });
            
            // 3. CompleteRegistration Event
            fbq('track', 'CompleteRegistration', {
                registration_method: 'Telegram_Join_Button',
                content_name: 'PANKAJ_STOCK_SIGNALS',
                status: 'initiated_join',
                button_used: buttonName,
                expert: CONFIG.EXPERT_NAME,
                pixel_id: CONFIG.PIXEL_ID,
                telegram_code: CONFIG.TELEGRAM_CODE
            });
            
            // 4. Contact Event
            fbq('track', 'Contact', {
                contact_method: 'Telegram_Channel',
                content_name: 'Pankaj_Bhardwaj_Telegram_Join',
                expert: CONFIG.EXPERT_NAME,
                pixel_id: CONFIG.PIXEL_ID,
                telegram_code: CONFIG.TELEGRAM_CODE
            });
            
            // 5. CustomEvent for deeper analytics
            fbq('trackCustom', 'PankajTelegramJoin', {
                button_name: buttonName,
                button_label: buttonName,
                position_on_page: position,
                page_section: 'cta_telegram',
                timestamp: eventTime,
                device_type: deviceType,
                expert: CONFIG.EXPERT_NAME,
                pixel_id: CONFIG.PIXEL_ID,
                source: 'pankaj_bhardwaj_landing',
                telegram_code: CONFIG.TELEGRAM_CODE,
                telegram_link: CONFIG.TELEGRAM_LINK
            });
            
            console.log('[Pixel ' + CONFIG.PIXEL_ID + '] ✅ Events: Lead, Subscribe, CompleteRegistration, Contact, CustomEvent for "' + buttonName + '" at "' + position + '"');
            showToastMessage('✅ Joined! Events tracked (' + CONFIG.PIXEL_ID + ')', 1500);
        }
        
        // Helper to setup button tracking
        function setupButtonWithTracking(button, defaultName, defaultPosition) {
            if (!button) return null;
            var buttonName = button.getAttribute('data-button-name') || defaultName;
            var position = button.getAttribute('data-position') || defaultPosition;
            
            // Clone to replace and ensure fresh listener
            var newBtn = button.cloneNode(true);
            if (button.parentNode) {
                button.parentNode.replaceChild(newBtn, button);
            }
            newBtn.setAttribute('href', CONFIG.TELEGRAM_LINK);
            newBtn.setAttribute('target', '_blank');
            newBtn.setAttribute('rel', 'noopener noreferrer');
            
            var isProcessing = false;
            
            newBtn.addEventListener('click', function(e) {
                if (isProcessing) return;
                isProcessing = true;
                
                var targetUrl = this.href;
                e.preventDefault();
                
                fireAllTrackingEvents(newBtn, buttonName, position);
                
                setTimeout(function() {
                    if (targetUrl && targetUrl !== '#') {
                        window.open(targetUrl, '_blank');
                    }
                    isProcessing = false;
                }, 350);
            });
            return newBtn;
        }
        
        // Grab both buttons
        var topBtn = document.getElementById('joinBtnTop');
        var bottomBtn = document.getElementById('joinBtnBottom');
        
        // Apply tracking
        var trackedTop = setupButtonWithTracking(topBtn, 'Join Button Primary (Below Name)', 'first_under_name');
        var trackedBottom = setupButtonWithTracking(bottomBtn, 'Join Button Secondary (Below Name 2)', 'second_under_name');
        
        // ========== SCROLL DEPTH TRACKING ==========
        var scroll25 = false, scroll50 = false, scroll75 = false;
        window.addEventListener('scroll', function() {
            var winScroll = window.scrollY;
            var docHeight = document.body.scrollHeight - window.innerHeight;
            if (docHeight <= 0) return;
            var percent = (winScroll / docHeight) * 100;
            
            if (!scroll25 && percent >= 25) {
                if (typeof fbq === 'function') {
                    fbq('track', 'ScrollDepth', { depth: '25%', page: 'pankaj_bhardwaj_landing', expert: CONFIG.EXPERT_NAME, pixel_id: CONFIG.PIXEL_ID });
                }
                scroll25 = true;
            }
            if (!scroll50 && percent >= 50) {
                if (typeof fbq === 'function') {
                    fbq('track', 'ScrollDepth', { depth: '50%', page: 'pankaj_bhardwaj_landing', expert: CONFIG.EXPERT_NAME, pixel_id: CONFIG.PIXEL_ID });
                }
                scroll50 = true;
            }
            if (!scroll75 && percent >= 75) {
                if (typeof fbq === 'function') {
                    fbq('track', 'ScrollDepth', { depth: '75%', page: 'pankaj_bhardwaj_landing', expert: CONFIG.EXPERT_NAME, pixel_id: CONFIG.PIXEL_ID });
                }
                scroll75 = true;
            }
        });
        
        // ========== PAGE VIEW TRACKING ==========
        if (typeof fbq === 'function') {
            fbq('track', 'ViewContent', {
                content_name: 'Pankaj_Bhardwaj_Telegram_Landing',
                content_category: 'StockMarket_Channel_Pankaj',
                currency: 'INR',
                value: 0,
                expert: CONFIG.EXPERT_NAME,
                pixel_id: CONFIG.PIXEL_ID,
                telegram_code: CONFIG.TELEGRAM_CODE
            });
            console.log('[Pixel ' + CONFIG.PIXEL_ID + '] ViewContent tracked. Expert: ' + CONFIG.EXPERT_NAME);
            console.log('📎 New Telegram Link: ' + CONFIG.TELEGRAM_LINK);
        }
        
        // ========== TIME ON PAGE TRACKING ==========
        var startTime = Date.now();
        var timeTrackedFlag = false;
        
        function trackTimeSpent() {
            if (timeTrackedFlag) return;
            var seconds = Math.floor((Date.now() - startTime) / 1000);
            if (seconds > 5 && typeof fbq === 'function') {
                fbq('trackCustom', 'TimeOnPage', {
                    seconds_spent: seconds,
                    page: 'pankaj_bhardwaj_landing',
                    channel: CONFIG.CHANNEL_NAME,
                    expert: CONFIG.EXPERT_NAME,
                    pixel_id: CONFIG.PIXEL_ID
                });
                console.log('[Pixel ' + CONFIG.PIXEL_ID + '] Time on page tracked: ' + seconds + ' seconds');
                timeTrackedFlag = true;
            }
        }
        window.addEventListener('beforeunload', trackTimeSpent);
        
        // ========== RE-FIRE PAGEVIEW ==========
        if (typeof fbq === 'function') {
            setTimeout(function() {
                fbq('track', 'PageView', {
                    revisit_confirmation: true,
                    theme: 'premium_dark',
                    tracking_status: 'active',
                    expert: CONFIG.EXPERT_NAME,
                    pixel_id: CONFIG.PIXEL_ID,
                    telegram_code: CONFIG.TELEGRAM_CODE
                });
            }, 500);
        }
        
        // ========== CONSOLE STATUS ==========
        console.log('%c🔥 PANKAJ BHARDWAJ | 2 BUTTONS - NEW PIXEL & LINK 🔥', 'color: #FFB347; font-weight: bold; font-size: 15px;');
        console.log('✅ Expert Name: ' + CONFIG.EXPERT_NAME);
        console.log('✅ New Pixel ID: ' + CONFIG.PIXEL_ID);
        console.log('✅ Updated Telegram Link: ' + CONFIG.TELEGRAM_LINK);
        console.log('✅ Telegram Code: ' + CONFIG.TELEGRAM_CODE);
        console.log('✅ Total Tracked Buttons: 2 (Subscribe Button REMOVED)');
        console.log('   - Primary Join (below name)');
        console.log('   - Secondary Join (second below name)');
        console.log('✅ Events per click: Lead, Subscribe, CompleteRegistration, Contact, CustomEvent');
        console.log('✅ Additional tracking: ScrollDepth, TimeOnPage, ViewContent');
        
        // Debug helper
        window.pankajPixelHelper = {
            config: function() { console.log('Pixel Config:', CONFIG); },
            testEvent: function() {
                if (typeof fbq === 'function') {
                    fbq('track', 'Lead', { test: true, source: 'console', expert: CONFIG.EXPERT_NAME, pixel_id: CONFIG.PIXEL_ID, telegram_code: CONFIG.TELEGRAM_CODE });
                    console.log('✅ Test Lead event sent to Pixel ID: ' + CONFIG.PIXEL_ID);
                } else {
                    console.error('❌ fbq not available');
                }
            },
            status: function() {
                console.log('📊 Tracking Status:');
                console.log('  Expert: ' + CONFIG.EXPERT_NAME);
                console.log('  Pixel Ready: ' + (typeof fbq === 'function' ? '✅' : '❌'));
                console.log('  Pixel ID: ' + CONFIG.PIXEL_ID);
                console.log('  Telegram Link: ' + CONFIG.TELEGRAM_LINK);
                console.log('  Top Button exists: ' + !!document.getElementById('joinBtnTop'));
                console.log('  Bottom Button exists: ' + !!document.getElementById('joinBtnBottom'));
            }
        };
        console.log('💡 Debug: type "pankajPixelHelper.status()" or "pankajPixelHelper.testEvent()" in console');
        
    })();
</script>

<!-- Fallback noscript images -->
<noscript>
    <img height="1" width="1" style="display:none" src="https://www.facebook.com/tr?id=4954209871473065&ev=Lead&noscript=1"/>
    <img height="1" width="1" style="display:none" src="https://www.facebook.com/tr?id=4954209871473065&ev=Subscribe&noscript=1"/>
    <img height="1" width="1" style="display:none" src="https://www.facebook.com/tr?id=4954209871473065&ev=CompleteRegistration&noscript=1"/>
    <img height="1" width="1" style="display:none" src="https://www.facebook.com/tr?id=4954209871473065&ev=Contact&noscript=1"/>
    <img height="1" width="1" style="display:none" src="https://www.facebook.com/tr?id=4954209871473065&ev=ViewContent&noscript=1"/>
